# Test scenario build artifacts - these are only for local testing
test-scenarios/*/node_modules/
test-scenarios/*/target/
test-scenarios/*/dist/
test-scenarios/*/build/
test-scenarios/*/coverage/

# Temporary files
test-scenarios/*/.DS_Store
test-scenarios/*/.env
test-scenarios/*/.env.local

# Dependencies installed for scripts
node_modules/

# Node.js テンプレートバリアントのビルド成果物（pnpm install / tsc --incremental で生成）
nodejs/*/dist/
nodejs/*/node_modules/